{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Remote Touchpad",
  "version": "0.1.0",
  "identifier": "com.remote-touchpad.app",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "./ui"
  },
  "app": {
    "windows": [
      {
        "title": "Remote Touchpad",
        "width": 400,
        "height": 550,
        "resizable": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "targets": ["nsis", "deb"],
    "active": true,
    "resources": ["../frontend/*", "../frontend/iconfont/*"]
  }
}
